<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:title="Lista de compras"
        android:titleTextColor="@android:color/black"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#DDDDDD"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="8dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerTodosProdutos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#DDDDDD"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/botaoCadastrarProduto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cadastrar produtos"
        android:layout_marginTop="10dp"/>

    <Button
        android:id="@+id/btnSalvarCategoria"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cadastrar/Gerenciar categorias"
        android:minHeight="48dp" />

    <Button
        android:id="@+id/botaoZerarQuantidades"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Zerar quantidades"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/botaoLimparComprados"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🗑   Excluir comprados"
        android:layout_marginTop="8dp"/>
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#DDDDDD"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="28dp"/>

</LinearLayout>